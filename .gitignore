# Ignore root data folder if it contains processed samples (optional, but good practice for GitHub)
# data/processed/

# Allow some small sample data
!data/samples/

# Allow audio results (hindi vocals + mixed output)
!src/data/hindi_vocals/**/*.wav
!src/data/hindi_vocals/**/*.txt
!src/data/output/*.wav

